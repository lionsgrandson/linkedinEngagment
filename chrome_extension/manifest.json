{
  "manifest_version": 3,
  "name": "CodeCrafter Social Bridge",
  "version": "3.7.0",
  "description": "Connects the local Ollama engagement bot to signed-in LinkedIn and Instagram tabs.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.instagram.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "instagram_content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
