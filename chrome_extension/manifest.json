{
  "manifest_version": 3,
  "name": "CodeCrafter LinkedIn Bridge",
  "version": "3.2.0",
  "description": "Connects the local Ollama engagement bot to the signed-in LinkedIn tab.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://www.linkedin.com/*", "http://127.0.0.1:8765/*"],
  "background": {"service_worker": "service_worker.js"},
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
